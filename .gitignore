# Monorepo: `apps/*` and `packages/*` are tracked except generated paths below.
# Canonical docs prose: `docs/`; VitePress copy: `apps/docs/content/` (ignored — run `pnpm docs:sync`).

node_modules/
dist/
*.log
.env
.env.*
.DS_Store
porting-map.md
i18nprune.zip
coverage/
# Cursor — keep shared `.cursor/rules/*.mdc` in git; ignore other local/workspace-only entries
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.agents/
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/mcp.json

# Docs site (VitePress)
# Mirrored from repo `docs/` by `pnpm docs:sync` (also runs before `pnpm docs:build`). Do not commit.
apps/docs/content/
apps/docs/node_modules/
apps/docs/.vitepress/.temp/
apps/docs/.vitepress/cache/
apps/docs/.vitepress/dist/
apps/docs/package-lock.json
apps/docs/tsconfig.tsbuildinfo

# Landing site (Vite + React — install deps inside apps/web/)
apps/web/node_modules/
apps/web/dist/
apps/web/package-lock.json

# Report site (Vite — install deps inside apps/report/)
apps/report/node_modules/
apps/report/dist/
apps/report/package-lock.json

# Maintainer scratch (never commit). Rest of `maintainer/` stays tracked for collaborators.
# Do not gitignore all of `maintainer/` — see `maintainer/README.md`.
maintainer/temp/

# Cloudflare Workers — local Wrangler caches (sqlite, DO state)
apps/workers/**/.wrangler/
