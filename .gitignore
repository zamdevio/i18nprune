# Mirrored from repo root `docs/` — run `pnpm docs:sync` or `pnpm run sync` in apps/docs
apps/docs/content/

# Landing site (Vite + React — install deps inside apps/web/)
apps/web/node_modules/
apps/web/dist/
apps/web/package-lock.json

# Report site (Vite — install deps inside apps/report/)
apps/report/node_modules/
apps/report/dist/
apps/report/package-lock.json

