{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "cursor",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/extension"],
      "outFiles": ["${workspaceFolder}/apps/extension/out/**/*.js"],
      "preLaunchTask": "ext:build"
    },
    {
      "name": "Run Extension (watch)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "cursor",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/extension"],
      "outFiles": ["${workspaceFolder}/apps/extension/out/**/*.js"],
      "preLaunchTask": "ext:watch"
    }
  ]
}
