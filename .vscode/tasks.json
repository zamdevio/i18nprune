{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ext:build",
      "type": "shell",
      "command": "pnpm ext:build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$esbuild"]
    },
    {
      "label": "ext:watch",
      "type": "shell",
      "command": "pnpm ext:watch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "group": "build",
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(\\[watch\\] build finished|Done in \\d+ms)"
        }
      }
    }
  ]
}
