{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/cli/src/*"],
      "@zamdevio/i18nprune/report": ["packages/report/src/index.ts"]
    }
  },
  "include": [
    "packages/cli/bin/**/*.ts",
    "packages/cli/src/**/*.ts",
    "packages/report/**/*.ts",
    "scripts/**/*.ts",
    "tests/integration/**/*.ts",
    "vitest.config.ts"
  ]
}
