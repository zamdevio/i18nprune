import { defineConfig } from '@zamdevio/i18nprune/config';

export default defineConfig({
  /** Source locale JSON (basename is the source-of-truth code unless `sourceLocaleCode` is set for messages). */
  source: 'locales/en.json',
  /** Optional: override the source locale **label** in CLI messages (defaults to basename of `source`). */
  // sourceLocaleCode: 'en',
  localesDir: 'locales',
  src: 'src',
  functions: ['t'],
  /** Default for global `--report-format` when the CLI flag is omitted. */
  // reportFormat: 'json',
  policies: {
    preserve: {},
    parity: {},
  },
});
