{
  "name": "@zamdevio/i18nprune",
  "version": "0.1.0",
  "description": "Production-grade i18n toolkit. CLI + stable programmatic API for validation, sync, pruning, generation and quality control of translation files.",
  "type": "module",
  "bin": {
    "i18nprune": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js",
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./report": {
      "types": "./dist/report.d.ts",
      "import": "./dist/report.js",
      "default": "./dist/report.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup && node scripts/flatten-cli-dts.mjs && node scripts/report/flatten-report-dts.mjs && npm run report:build && node scripts/report/copy-template.mjs",
    "dev": "tsx --tsconfig tsconfig.json packages/cli/bin/cli.ts",
    "generate:languages": "tsx --tsconfig tsconfig.json scripts/languages/generate.ts",
    "docs:sync": "node apps/docs/scripts/sync-content.js --once --no-git",
    "docs:dev": "pnpm --filter @zamdevio/i18nprune-docs dev",
    "docs:build": "pnpm --filter @zamdevio/i18nprune-docs build",
    "docs:deploy": "pnpm docs:build && wrangler pages deploy apps/docs/out --project-name=docs-i18nprune",
    "web:dev": "pnpm --filter i18nprune-web dev",
    "web:build": "pnpm --filter i18nprune-web build",
    "web:preview": "pnpm --filter i18nprune-web preview",
    "web:deploy": "pnpm web:build && wrangler pages deploy apps/web/dist --project-name=i18nprune",
    "github:dev": "pnpm --filter @zamdevio/i18nprune-github dev",
    "github:build": "pnpm --filter @zamdevio/i18nprune-github typecheck",
    "github:deploy": "pnpm github:build && pnpm --filter @zamdevio/i18nprune-github run deploy",
    "report:dev": "vite --config apps/report/vite.config.ts",
    "report:build": "vite build --config apps/report/vite.config.ts",
    "report:deploy": "pnpm report:build && wrangler pages deploy apps/report/dist --project-name=report-i18nprune",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "locale",
    "translation",
    "cli",
    "cleanup",
    "ripgrep",
    "localization",
    "developer-tools",
    "i18nprune"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "jiti": "^2.6.1",
    "string-width": "^7.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.3",
    "vite-plugin-singlefile": "^2.0.1",
    "vitest": "^3.2.0",
    "wrangler": "^4.54.0"
  }
}
