{
  "name": "i18nprune",
  "version": "0.1.0",
  "description": "Production-grade i18n toolkit. CLI + stable programmatic API for validation, sync, pruning, generation and quality control of translation files.",
  "type": "module",
  "bin": {
    "i18nprune": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js",
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./core/config": {
      "types": "./dist/core/src/config/index.d.ts",
      "import": "./dist/core/config.js",
      "default": "./dist/core/config.js"
    },
    "./core/runtime/node": {
      "types": "./dist/core/src/runtime/exports/node.d.ts",
      "import": "./dist/core/runtime/node.js",
      "default": "./dist/core/runtime/node.js"
    },
    "./core/runtime/web": {
      "types": "./dist/core/src/runtime/exports/web.d.ts",
      "import": "./dist/core/runtime/web.js",
      "default": "./dist/core/runtime/web.js"
    },
    "./core/runtime/edge": {
      "types": "./dist/core/src/runtime/exports/edge.d.ts",
      "import": "./dist/core/runtime/edge.js",
      "default": "./dist/core/runtime/edge.js"
    },
    "./report": {
      "types": "./dist/report/src/index.d.ts",
      "import": "./dist/report.js",
      "default": "./dist/report.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "pnpm run cli:build && pnpm run web:build && pnpm run landing:build && pnpm run docs:build && pnpm run ext:build && pnpm run worker:build && pnpm run meta:build",
    "typecheck": "pnpm run core:typecheck && pnpm run cli:typecheck && pnpm run ui:typecheck && pnpm run ui:purity && pnpm run report:typecheck && pnpm run web:typecheck && pnpm run landing:typecheck && pnpm run docs:typecheck && pnpm run worker:build && pnpm run meta:build && pnpm run ext:web:typecheck",
    "test": "vitest run",
    "test:summary": "pnpm test 2>&1 | grep -E 'Test Files|Tests|Start at|Duration'",
    "cli:build": "tsup && npm run report:build && node packages/report/scripts/build-assets.mjs",
    "cli:dev": "tsx --tsconfig tsconfig.json packages/cli/bin/cli.ts",
    "cli:typecheck": "tsc --noEmit",
    "core:typecheck": "pnpm --filter @i18nprune/core typecheck",
    "ui:typecheck": "pnpm --filter @i18nprune/ui typecheck",
    "ui:purity": "node scripts/ui/purity-check.mjs",
    "ui:sync:swagger-css": "node scripts/ui/sync-swagger-overrides.mjs",
    "ui:check:swagger-css": "node scripts/ui/sync-swagger-overrides.mjs && git diff --exit-code packages/ui/src/swagger/overrides-css.ts",
    "generate:languages": "tsx --tsconfig tsconfig.json scripts/catalog/run.ts",
    "docs:sync": "node apps/docs/scripts/sync.js",
    "docs:dev": "pnpm --filter @i18nprune/docs dev",
    "docs:build": "pnpm --filter @i18nprune/docs build",
    "docs:typecheck": "pnpm --filter @i18nprune/docs typecheck",
    "docs:deploy": "pnpm docs:build && wrangler pages deploy apps/docs/.vitepress/dist --project-name=docs-i18nprune",
    "web:dev": "pnpm --filter @i18nprune/web dev",
    "web:build": "pnpm --filter @i18nprune/web build",
    "web:typecheck": "pnpm --filter @i18nprune/web typecheck",
    "web:preview": "pnpm --filter @i18nprune/web preview",
    "web:deploy": "pnpm web:build && wrangler pages deploy apps/web/dist --project-name=web-i18nprune",
    "landing:dev": "pnpm --filter @i18nprune/landing dev",
    "landing:build": "pnpm --filter @i18nprune/landing build",
    "landing:typecheck": "pnpm --filter @i18nprune/landing typecheck",
    "landing:deploy": "pnpm landing:build && wrangler pages deploy apps/landing/dist --project-name=landing-i18nprune",
    "meta:dev": "pnpm --filter @i18nprune/worker-meta dev",
    "meta:build": "pnpm --filter @i18nprune/worker-meta build",
    "meta:deploy": "pnpm meta:build && pnpm --filter @i18nprune/worker-meta run deploy",
    "worker:dev": "pnpm --filter @i18nprune/worker-i18nprune dev",
    "worker:build": "pnpm --filter @i18nprune/worker-i18nprune build",
    "worker:deploy": "pnpm worker:build && pnpm --filter @i18nprune/worker-i18nprune run deploy",
    "report:dev": "vite --config apps/report/vite.config.ts",
    "report:build": "vite build --config apps/report/vite.config.ts",
    "report:typecheck": "pnpm --filter @i18nprune/report typecheck",
    "report:deploy": "pnpm report:build && wrangler pages deploy apps/report/dist --project-name=report-i18nprune",
    "ext:compile": "pnpm --dir apps/extension run compile",
    "ext:watch": "pnpm --dir apps/extension run watch",
    "ext:build": "pnpm --dir apps/extension run build",
    "ext:web:dev": "pnpm --dir apps/extension/src/webview run dev",
    "ext:web:build": "pnpm --dir apps/extension run build:webview",
    "ext:web:typecheck": "pnpm --dir apps/extension/src/webview run typecheck",
    "ext:typecheck": "pnpm --dir apps/extension run typecheck",
    "knip": "knip",
    "madge:circular": "madge --circular --extensions ts,tsx --ts-config tsconfig.json packages/core/src packages/cli/src packages/report/src packages/ui/src",
    "madge:orphans": "madge --orphans --extensions ts,tsx --ts-config tsconfig.json packages/core/src packages/cli/src packages/report/src packages/ui/src",
    "madge:leaves": "madge --leaves --extensions ts,tsx --ts-config tsconfig.json packages/core/src packages/cli/src packages/report/src packages/ui/src",
    "empty:dir": "find . -path '*node_modules' -prune -o -path '*/.wrangler' -prune -o -path ./.git -prune -o -type d -empty -print",
    "empty:file": "find . -path '*node_modules' -prune -o -path '*/.wrangler' -prune -o -path ./.git -prune -o -type f -empty -print",
    "empty:dir:del": "find . -type d -empty ! -path '*/node_modules' ! -path '*/node_modules/*' ! -path '*/.wrangler' ! -path '*/.wrangler/*' ! -path './.git' ! -path './.git/*' -print -delete",
    "empty:file:del": "find . -type f -empty ! -path '*/node_modules/*' ! -path '*/.wrangler/*' ! -path './.git/*' -print -delete",
    "files": "printf \"Source files (.ts, .tsx):\" && find . -path './node_modules' -prune -o -path './.git' -prune -o -path './dist' -prune -o -path './build' -prune -o -path './coverage' -prune -prune -o -path './out' -prune -o -path '*/.wrangler' -prune -o \\( -name '*.ts' -o -name '*.tsx' \\) -print | wc -l",
    "lines": "printf \"Lines of code (.ts, .tsx):\" && find . -path './node_modules' -prune -o -path './.git' -prune -o -path './dist' -prune -o -path './build' -prune -o -path './coverage' -prune prune -o -path './out' -prune -o -path '*/.wrangler' -prune -o \\( -name '*.ts' -o -name '*.tsx' \\) -print | xargs wc -l 2>/dev/null | tail -1",
    "stats": "pnpm files && echo '' && pnpm lines"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translation",
    "locale",
    "json",
    "typescript",
    "cli",
    "sdk",
    "validate",
    "sync",
    "generate",
    "cleanup",
    "review",
    "quality",
    "doctor",
    "machine-translation",
    "translation-management",
    "vscode",
    "extension",
    "cloudflare-workers",
    "report",
    "share",
    "cache",
    "developer-tools",
    "ci",
    "i18nprune"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/core": "^10.3.2",
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "jiti": "^2.6.1",
    "string-width": "^7.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@i18nprune/core": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "knip": "^6.12.0",
    "madge": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.3",
    "vitest": "^3.2.0",
    "wrangler": "^4.54.0"
  }
}
