{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "strict": false
  },
  "include": ["**/*.ts", "**/*.tsx", "react-jsx-shim.d.ts"]
}
