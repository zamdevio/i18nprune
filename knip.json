{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "tests/fixtures/**",
    "tests/publish-types/fixture/**",
    "examples/sdk/**",
    "i18nprune.config.ts",
    "packages/core/src/extractor/index.ts",
    "packages/core/src/runtime/factory/index.ts",
    "packages/core/src/runtime/guards/index.ts",
    "packages/core/src/runtime/index.ts",
    "packages/core/src/shared/index.ts",
    "packages/core/src/shared/result/index.ts",
    "apps/workers/**/public/**"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["printf", "tail"],
  "workspaces": {
    "apps/landing": {
      "entry": ["src/**/*.{ts,tsx}"],
      "ignore": ["functions/**"],
      "ignoreDependencies": ["@cloudflare/workers-types", "@resvg/resvg-wasm"]
    },
    "apps/extension": {
      "project": ["src/extension/**/*.ts"]
    },
    "apps/extension/src/webview": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
