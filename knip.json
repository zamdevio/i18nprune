{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "tests/fixtures/**",
    "tests/publish-types/fixture/**",
    "examples/sdk/**",
    "i18nprune.config.ts",
    "packages/core/src/extractor/index.ts",
    "packages/core/src/runtime/factory/index.ts",
    "packages/core/src/runtime/guards/index.ts",
    "packages/core/src/runtime/index.ts",
    "packages/core/src/shared/index.ts",
    "packages/core/src/shared/result/index.ts",
    "apps/workers/**/public/**",
    "apps/*/functions/**"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["printf", "awk"],
  "workspaces": {
    "apps/landing": {
      "entry": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@cloudflare/workers-types"]
    },
    "apps/web": {
      "entry": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@cloudflare/workers-types"]
    },
    "apps/report": {
      "entry": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@cloudflare/workers-types"]
    },
    "apps/docs": {
      "entry": ["content/**/*.md", ".vitepress/**/*.{ts,mts}"],
      "ignoreDependencies": ["@cloudflare/workers-types"]
    },
    "apps/releases": {
      "entry": ["src/**/*.{ts,tsx}", "scripts/**/*.ts"],
      "project": ["src/**/*.{ts,tsx}", "scripts/**/*.ts"],
      "ignoreDependencies": ["@cloudflare/workers-types"]
    },
    "apps/git": {
      "entry": ["src/**/*.{ts,tsx}", "scripts/**/*.ts"],
      "project": ["src/**/*.{ts,tsx}", "scripts/**/*.ts"],
      "ignoreDependencies": ["@cloudflare/workers-types"]
    },
    "apps/extension": {
      "project": ["src/extension/**/*.ts"]
    },
    "apps/extension/src/webview": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/seo": {
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
