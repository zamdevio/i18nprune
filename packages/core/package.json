{
  "name": "@i18nprune/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Pure domain engine package for i18nprune.",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./shared": {
      "types": "./src/shared/index.ts",
      "default": "./src/shared/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./types/shared": {
      "types": "./src/types/shared/index.ts",
      "default": "./src/types/shared/index.ts"
    },
    "./locales": {
      "types": "./src/namespaces/locales.ts",
      "default": "./src/namespaces/locales.ts"
    },
    "./generate": {
      "types": "./src/generate/index.ts",
      "default": "./src/generate/index.ts"
    },
    "./init": {
      "types": "./src/init/index.ts",
      "default": "./src/init/index.ts"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "default": "./src/config/index.ts"
    },
    "./report-schema": {
      "types": "./src/shared/report/index.ts",
      "default": "./src/shared/report/index.ts"
    },
    "./sync": {
      "types": "./src/sync/index.ts",
      "default": "./src/sync/index.ts"
    },
    "./validate": {
      "types": "./src/validate/index.ts",
      "default": "./src/validate/index.ts"
    },
    "./missing": {
      "types": "./src/missing/index.ts",
      "default": "./src/missing/index.ts"
    },
    "./cleanup": {
      "types": "./src/cleanup/index.ts",
      "default": "./src/cleanup/index.ts"
    },
    "./quality": {
      "types": "./src/quality/index.ts",
      "default": "./src/quality/index.ts"
    },
    "./runtime/node": {
      "types": "./src/runtime/exports/node.ts",
      "default": "./src/runtime/exports/node.ts"
    },
    "./runtime/web": {
      "types": "./src/runtime/exports/web.ts",
      "default": "./src/runtime/exports/web.ts"
    },
    "./runtime/edge": {
      "types": "./src/runtime/exports/edge.ts",
      "default": "./src/runtime/exports/edge.ts"
    },
    "./runtime/helpers/sync": {
      "types": "./src/runtime/exports/helpers/sync.ts",
      "default": "./src/runtime/exports/helpers/sync.ts"
    }
  }
}
