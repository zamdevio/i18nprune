{
  "name": "@i18nprune/core",
  "version": "0.1.3",
  "private": false,
  "type": "module",
  "description": "Pure domain engine package for i18nprune.",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsup --config tsup.subpaths-dts.config.ts && node ../../scripts/dts/fix-core-dts.mjs --no-test --dts=packages/core/dist/index.d.ts",
    "prepack": "I18NPRUNE_PUBLISH=1 pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "fflate": "^0.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js",
      "default": "./dist/shared.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./types/shared": {
      "types": "./dist/types/shared.d.ts",
      "import": "./dist/types/shared.js",
      "default": "./dist/types/shared.js"
    },
    "./locales": {
      "types": "./dist/locales.d.ts",
      "import": "./dist/locales.js",
      "default": "./dist/locales.js"
    },
    "./generate": {
      "types": "./dist/generate.d.ts",
      "import": "./dist/generate.js",
      "default": "./dist/generate.js"
    },
    "./init": {
      "types": "./dist/init.d.ts",
      "import": "./dist/init.js",
      "default": "./dist/init.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./report-schema": {
      "types": "./dist/report-schema.d.ts",
      "import": "./dist/report-schema.js",
      "default": "./dist/report-schema.js"
    },
    "./sync": {
      "types": "./dist/sync.d.ts",
      "import": "./dist/sync.js",
      "default": "./dist/sync.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js",
      "default": "./dist/validate.js"
    },
    "./missing": {
      "types": "./dist/missing.d.ts",
      "import": "./dist/missing.js",
      "default": "./dist/missing.js"
    },
    "./cleanup": {
      "types": "./dist/cleanup.d.ts",
      "import": "./dist/cleanup.js",
      "default": "./dist/cleanup.js"
    },
    "./quality": {
      "types": "./dist/quality.d.ts",
      "import": "./dist/quality.js",
      "default": "./dist/quality.js"
    },
    "./runtime/node": {
      "types": "./dist/runtime/node.d.ts",
      "import": "./dist/runtime/node.js",
      "default": "./dist/runtime/node.js"
    },
    "./runtime/web": {
      "types": "./dist/runtime/web.d.ts",
      "import": "./dist/runtime/web.js",
      "default": "./dist/runtime/web.js"
    },
    "./runtime/edge": {
      "types": "./dist/runtime/edge.d.ts",
      "import": "./dist/runtime/edge.js",
      "default": "./dist/runtime/edge.js"
    },
    "./runtime/helpers/sync": {
      "types": "./dist/runtime/helpers/sync.d.ts",
      "import": "./dist/runtime/helpers/sync.js",
      "default": "./dist/runtime/helpers/sync.js"
    }
  }
}
