{
  "name": "i18nprune",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-content.js --once --no-git",
    "sync:watch": "node scripts/sync-content.js --dev --no-git",
    "dev": "npm run sync && PORT=8181 next dev",
    "build": "npm run sync && next build",
    "postbuild": "pagefind --site out --output-path out/_pagefind",
    "start": "PORT=8181 next start"
  },
  "dependencies": {
    "next": "^16.2.2",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "lodash-es": "4.18.1"
  }
}
