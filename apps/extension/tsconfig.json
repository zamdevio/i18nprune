{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "rootDir": "src",
    "types": ["node", "vscode"]
  },
  "include": ["src/extension/**/*.ts"]
}
