{
  "name": "@i18nprune/landing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "vite --host 0.0.0.0 --port 3000",
    "dev": "vite --host 0.0.0.0 --port 3000",
    "prebuild": "pnpm --filter @i18nprune/seo run build",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "deploy": "pnpm build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@i18nprune/seo": "workspace:*",
    "@shikijs/langs": "4.0.2",
    "@shikijs/themes": "4.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.2.0"
  }
}
