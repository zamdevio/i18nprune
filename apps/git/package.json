{
  "name": "@i18nprune/git",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "sync": "tsx scripts/sync.ts",
    "validate": "tsx scripts/validate/data.ts && tsx scripts/validate/phases.ts",
    "validate:data": "tsx scripts/validate/data.ts",
    "validate:phases": "tsx scripts/validate/phases.ts",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "predev": "pnpm run sync && pnpm run generate:sitemap",
    "dev": "vite",
    "prebuild": "pnpm --filter @i18nprune/seo run build && pnpm run sync && pnpm run validate && pnpm run generate:sitemap",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm run sync && pnpm run validate && tsc --noEmit",
    "deploy": "pnpm build && wrangler pages deploy dist --project-name=git-i18nprune"
  },
  "dependencies": {
    "@i18nprune/ui": "workspace:*",
    "lucide-react": "^0.546.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.1",
    "@i18nprune/seo": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.4",
    "typescript": "^5.9.0",
    "vite": "^6.0.3"
  }
}
