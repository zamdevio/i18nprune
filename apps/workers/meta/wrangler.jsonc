{
  "name": "meta",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-14",
  "durable_objects": {
    "bindings": [
      {
        "name": "META_CACHE",
        "class_name": "MetaCacheDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1-meta-do",
      "new_sqlite_classes": ["MetaCacheDO"]
    }
  ],
  "routes": [
    {
      "pattern": "meta.i18nprune.dev",
      "custom_domain": true
    }
  ]
}
