{
  "name": "@i18nprune/releases",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Release portal SPA for releases.i18nprune.dev (CLI, core, extension streams).",
  "scripts": {
    "validate": "tsx scripts/validate.ts",
    "validate:strict": "tsx scripts/validate.ts --strict",
    "generate:catalog": "tsx scripts/generate.ts",
    "predev": "pnpm run generate:catalog",
    "dev": "vite",
    "prebuild": "pnpm --filter @i18nprune/seo run build && pnpm run validate && pnpm run generate:catalog",
    "build": "vite build",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm run generate:catalog && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "preview": "vite preview",
    "github-release-body": "tsx scripts/github-release-body.ts"
  },
  "dependencies": {
    "@i18nprune/seo": "workspace:*",
    "@i18nprune/ui": "workspace:*",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.16.4",
    "lucide-react": "^0.546.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.1",
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/semver": "^7.7.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.14.0",
    "postcss": "^8.5.3",
    "semver": "^7.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.3",
    "yaml": "^2.9.0"
  }
}
