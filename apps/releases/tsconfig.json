{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@i18nprune/ui/react/theme": ["../../packages/ui/src/react/theme/index.ts"],
      "@i18nprune/ui/react/pagination": ["../../packages/ui/src/react/pagination/index.ts"],
      "@i18nprune/ui/react/toolbar": ["../../packages/ui/src/react/toolbar/index.ts"],
      "@i18nprune/ui/utils/clipboard": ["../../packages/ui/src/utils/clipboard/index.ts"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/types/**/*.d.ts", "vite.config.ts", "src/features/release/migration"],
  "exclude": ["node_modules", "dist"]
}
