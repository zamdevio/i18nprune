  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.9.0",
    "vite": "^6.0.3",
    "vite-plugin-singlefile": "^2.0.1"
